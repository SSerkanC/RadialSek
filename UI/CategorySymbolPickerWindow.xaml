<Window x:Class="RadialSek.UI.CategorySymbolPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kategori Sembolü"
        Width="620"
        Height="760"
        Icon="../sek_logo.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFFFFF">
    <Border Background="#10141B"
            BorderBrush="#2B3340"
            BorderThickness="1"
            CornerRadius="22">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Height="32"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock Text="Kategori Sembolü"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#DDE6F1"/>
                <Button Width="30"
                        Height="26"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FFFFFF"
                        Click="OnCloseClicked">
                    <TextBlock Text="×"
                               FontSize="13"
                               FontWeight="Bold"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,10,0,0">
                <TextBlock Text="Sembol Arşivi"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="Modern görünümlü kategori sembolleri arasından seçim yapın."
                           Margin="0,8,0,0"
                           Foreground="#9BA7BA"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Height="128"
                    CornerRadius="18"
                    Background="#151A21"
                    BorderBrush="#2B3340"
                    BorderThickness="1"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="92"
                            Height="92"
                            CornerRadius="22"
                            Background="#11161D"
                            BorderBrush="#2F3746"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid x:Name="PreviewIconHost"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="16,4,0,0">
                        <TextBlock x:Name="PreviewTitleText"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="PreviewDescriptionText"
                                   Margin="0,8,0,0"
                                   Foreground="#9BA7BA"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="3"
                          Margin="0,18,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <WrapPanel x:Name="SymbolGrid"
                           Orientation="Horizontal"/>
            </ScrollViewer>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="ResetButton"
                        Content="Varsayılan Sembol"
                        Width="150"
                        Height="42"
                        Margin="0,0,8,0"
                        Click="OnResetClicked"/>
                <Button Content="İptal"
                        Width="100"
                        Height="42"
                        Margin="0,0,8,0"
                        Click="OnCancelClicked"/>
                <Button Content="Uygula"
                        Width="100"
                        Height="42"
                        Click="OnApplyClicked"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
