<Window x:Class="RadialSek.UI.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renk Sec"
        Width="456"
        Height="700"
        MinHeight="700"
        Icon="../sek_logo.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFFFFF">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F1217"/>
        <SolidColorBrush x:Key="CardBrush" Color="#151A21"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#2B3340"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F4B61A"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9BA7BA"/>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#11151B"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#1B212A"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Background="#0F1217"
            BorderBrush="#2B3340"
            BorderThickness="1"
            CornerRadius="22">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Height="32"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock Text="Sabit Renk"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#DDE6F1"/>
                <Button Width="30"
                        Height="26"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FFFFFF"
                        Click="OnCloseClicked">
                    <TextBlock Text="x"
                               FontSize="13"
                               FontWeight="Bold"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,10,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,4,0">
                    <TextBlock Margin="0,0,0,8"
                               Text="Hazir Renkler"
                               Foreground="#A9B5C8"
                               FontSize="12"
                               FontWeight="SemiBold"/>

                    <UniformGrid Columns="4"
                                 Margin="0,0,0,14">
                        <Button x:Name="PresetButton0" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton1" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton2" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton3" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton4" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton5" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton6" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton7" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton8" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton9" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton10" Margin="4" Height="36" Click="OnPresetClicked"/>
                        <Button x:Name="PresetButton11" Margin="4" Height="36" Click="OnPresetClicked"/>
                    </UniformGrid>

                    <Border Height="104"
                            CornerRadius="18"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="78"
                                  Height="78">
                                <Ellipse Fill="#10151C"
                                         Stroke="#3A4353"
                                         StrokeThickness="1.2"/>
                                <Ellipse x:Name="PreviewSwatch"
                                         Margin="10"
                                         Stroke="#E7EEF7"
                                         StrokeThickness="1.3"/>
                            </Grid>
                            <StackPanel Grid.Column="1"
                                        Margin="12,2,0,0">
                                <TextBlock Text="Canli Onizleme"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#DDE6F1"/>
                                <TextBlock x:Name="HexValueText"
                                           Margin="0,8,0,0"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF"/>
                                <TextBlock Text="Dilim rengi ve highlight bu tona gore uyarlanir."
                                           Margin="0,6,0,0"
                                           Foreground="#9BA7BA"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,16,0,8"
                               Text="Renk Kodu"
                               Foreground="#A9B5C8"
                               FontSize="12"
                               FontWeight="SemiBold"/>

                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14,12">
                        <TextBox x:Name="HexInputTextBox"
                                 Background="#0E1218"
                                 Foreground="White"
                                 BorderBrush="#313948"
                                 BorderThickness="1"
                                 Padding="12,8"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 TextChanged="OnHexInputTextChanged"/>
                    </Border>

                    <StackPanel Margin="0,16,0,0">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Kirmizi" Foreground="#DDE6F1"/>
                            <TextBlock x:Name="RedValueText" Grid.Column="1" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                        <Slider x:Name="RedSlider" Minimum="0" Maximum="255" ValueChanged="OnSliderChanged"/>

                        <Grid Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Yesil" Foreground="#DDE6F1"/>
                            <TextBlock x:Name="GreenValueText" Grid.Column="1" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                        <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" ValueChanged="OnSliderChanged"/>

                        <Grid Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mavi" Foreground="#DDE6F1"/>
                            <TextBlock x:Name="BlueValueText" Grid.Column="1" Foreground="{StaticResource MutedBrush}"/>
                        </Grid>
                        <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" ValueChanged="OnSliderChanged"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="ResetToThemeButton"
                        Content="Temaya Don"
                        Width="118"
                        Height="40"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnResetToThemeClicked"/>
                <Button Content="Iptal"
                        Width="100"
                        Height="40"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnCancelClicked"/>
                <Button Content="Uygula"
                        Width="100"
                        Height="40"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnApplyClicked"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
