<Window x:Class="RadialSek.UI.FeatureToggleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Özellikler"
        Width="520"
        Height="1000"
        Icon="../sek_logo.png"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFFFFF"
        PreviewKeyDown="OnPreviewKeyDown"
        PreviewMouseDown="OnPreviewMouseDown">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="#0B0D10" CornerRadius="18" BorderBrush="#29303D" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseDown" Height="40">
                <TextBlock Text="Özellikler"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="#A0ABC0"/>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Width="36"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="OnCloseWindowClicked">
                    <TextBlock Text="X" FontSize="14" FontWeight="Bold"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="20,10,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Özellikler"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Kısayolları ve davranış ayarlarını aşağıdaki ayrı bölümlerden yönetin."
                                   Margin="0,8,0,0"
                                   Foreground="#A0ABC0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,18">
                        <Border Padding="18"
                                CornerRadius="18"
                                Background="#15181E"
                                BorderBrush="#29303D"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Kısayollar"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Radial Menüyü Aç"
                                           Margin="0,14,0,8"
                                           FontWeight="SemiBold"/>
                                <Button x:Name="OpenShortcutCaptureButton"
                                        Height="46"
                                        HorizontalContentAlignment="Left"
                                        Padding="14,0"
                                        Click="OnOpenShortcutCaptureClicked"/>
                                <TextBlock Text="Butona tıklayın, sonra klavyeden kombinasyonu basın."
                                           Margin="0,8,0,18"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Programı Aktive/Deaktive Et"
                                           Margin="0,0,0,8"
                                           FontWeight="SemiBold"/>
                                <Button x:Name="ToggleShortcutCaptureButton"
                                        Height="46"
                                        HorizontalContentAlignment="Left"
                                        Padding="14,0"
                                        Click="OnToggleShortcutCaptureClicked"/>
                                <TextBlock Text="Bu kısayol programı oyun sırasında anlık olarak açıp kapatır."
                                           Margin="0,8,0,18"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Hedefleme Modu"
                                           Margin="0,0,0,8"
                                           FontWeight="SemiBold"/>
                                <Button x:Name="TargetingShortcutCaptureButton"
                                        Height="46"
                                        HorizontalContentAlignment="Left"
                                        Padding="14,0"
                                        Click="OnTargetingShortcutCaptureClicked"/>
                                <TextBlock Text="Menü açıkken bu tuşa basılı tutunca hedefleme çizgisi aktif olur."
                                           Margin="0,8,0,0"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#15181E"
                                BorderBrush="#29303D"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Özellikler"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <CheckBox x:Name="StartWithWindowsCheckBox"
                                          Content="Bilgisayar açıldığında otomatik başlat"
                                          Margin="0,14,0,16"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="Windows oturumuyla birlikte arka planda çalışır."
                                           Margin="26,-8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="OpenAnimationCheckBox"
                                          Content="Açılış animasyonunu kullan"
                                          Margin="0,0,0,16"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="Menü açılırken yumuşak giriş efekti oynatır."
                                           Margin="26,-8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="HoverLabelsCheckBox"
                                          Content="Hover başlıklarını göster"
                                          Margin="0,0,0,16"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="Öğelerin üstüne gelince küçük açıklayıcı etiket gösterir."
                                           Margin="26,-8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="CategoryLabelsCheckBox"
                                          Content="Kategori isimlerini ikon altında göster"
                                          Margin="0,0,0,16"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="Kategori öğelerinde sembolün altına başlık ekler."
                                           Margin="26,-8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="IconChromeCheckBox"
                                          Content="İkon çerçevesi ve parlamayı kullan"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="İkon kutularına çerçeve ve hafif glow uygular."
                                           Margin="26,8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="MonochromeBackdropCheckBox"
                                          Content="Arka planda siyah-beyaz filtre uygula"
                                          Margin="0,0,0,16"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock Text="Menü açılınca radial menü hariç ekranı siyah-beyaz gösterir."
                                           Margin="26,-8,0,16"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="LightIdleModeCheckBox"
                                          Content="Hafif bekleme modunu kullan"
                                          Checked="OnLightIdleModeCheckBoxChanged"
                                          Unchecked="OnLightIdleModeCheckBoxChanged"
                                          FontSize="15"
                                          FontWeight="SemiBold"/>
                                <TextBlock x:Name="LightIdleModeDescriptionTextBlock"
                                           Text="Radial menü belirlediğiniz süre boyunca kullanılmazsa overlay'i uyutup belleği hafifletir. Kısayola basınca yeniden uyanır."
                                           Margin="26,8,0,0"
                                           Foreground="#A0ABC0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Hafif bekleme süresi"
                                           Margin="26,16,0,8"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"/>
                                <Grid Margin="26,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider x:Name="LightIdleDelaySlider"
                                            Minimum="5"
                                            Maximum="60"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OnLightIdleDelaySliderValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LightIdleDelayValueTextBlock"
                                               Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="İptal"
                                Width="120"
                                Height="44"
                                Margin="0,0,10,0"
                                Click="OnCancelClicked"/>
                        <Button Content="Uygula"
                                Width="120"
                                Height="44"
                                Click="OnApplyClicked"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
