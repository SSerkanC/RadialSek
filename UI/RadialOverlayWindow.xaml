<Window x:Class="RadialSek.UI.RadialOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Opacity="0"
        WindowState="Maximized"
        PreviewKeyDown="OnPreviewKeyDown">
    <Grid x:Name="BackdropRoot"
          Background="#01000000"
          AllowDrop="True"
          PreviewDragOver="OnPreviewDragOver"
          PreviewDragLeave="OnPreviewDragLeave"
          PreviewDrop="OnPreviewDrop"
          PreviewKeyDown="OnPreviewKeyDown"
          PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
          PreviewMouseRightButtonDown="OnPreviewMouseRightButtonDown"
          PreviewMouseMove="OnPreviewMouseMove"
          PreviewMouseWheel="OnPreviewMouseWheel"
          MouseDown="OnBackdropMouseDown">
        <Image x:Name="MonochromeBackdropImage"
               Visibility="Collapsed"
               Stretch="Fill"
               SnapsToDevicePixels="True"
               IsHitTestVisible="False"/>
        <Canvas x:Name="RootCanvas"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="RootScaleTransform" ScaleX="0.985" ScaleY="0.985"/>
                    <TranslateTransform x:Name="RootTranslateTransform" Y="12"/>
                    <RotateTransform x:Name="RootRotateTransform" Angle="0"/>
                </TransformGroup>
            </Canvas.RenderTransform>
        </Canvas>
    </Grid>
</Window>
