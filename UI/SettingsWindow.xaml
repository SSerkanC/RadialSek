<Window x:Class="RadialSek.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RadialSek.Models"
        Title="Radial Sek Ayarlari"
        Width="1260" Height="920" MinWidth="1080" MinHeight="760"
        Icon="../sek_logo.png" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Foreground="#F3F5F8"
        PreviewKeyDown="OnPreviewKeyDown" PreviewMouseDown="OnPreviewMouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0B0D10"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#15181E"/>
        <SolidColorBrush x:Key="PanelBrushAlt" Color="#1A1E24"/>
        <SolidColorBrush x:Key="InputBrush" Color="#0E1115"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#29303D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F8BFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A0ABC0"/>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource PanelBrushAlt}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Height" Value="42"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F2F5FA"/>
            <Setter Property="Foreground" Value="#11161F"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#F2F5FA"/>
            <Setter Property="Foreground" Value="#11161F"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type models:MenuItemConfig}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Label}" Foreground="#FFFFFF" FontWeight="SemiBold"/>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource WindowBrush}" CornerRadius="14" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock Text="Radial Sek Ayarlari" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                <Button Width="36" Height="26" HorizontalAlignment="Right" Margin="0,0,8,0" Click="OnCloseWindowClicked" Style="{StaticResource BaseButtonStyle}" Content="X"/>
            </Grid>

            <Grid Grid.Row="1" Margin="14,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Ayarlar" FontSize="20" FontWeight="Bold"/>
                        <TextBox x:Name="SettingsSearchTextBox" Margin="0,10,0,10" TextChanged="OnSearchTextChanged"/>
                        <Button x:Name="NavGeneralButton" Tag="general" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Genel"/>
                        <Button x:Name="NavAudioButton" Tag="audio" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Ses"/>
                        <Button x:Name="NavControlsButton" Tag="controls" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Kontroller"/>
                        <Button x:Name="NavAppearanceButton" Tag="appearance" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Gorunum"/>
                        <Button x:Name="NavRingsButton" Tag="rings" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Efektler"/>
                        <Button x:Name="NavWeatherButton" Tag="weather" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Hava Durumu"/>
                        <Button x:Name="NavMenuButton" Tag="menu" Style="{StaticResource BaseButtonStyle}" Click="OnNavigationButtonClicked" Content="Menu Icerigi"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="NoResultsTextBlock" Visibility="Collapsed" Foreground="{StaticResource MutedBrush}" Text="Arama sonucu bulunamadi."/>

                            <Border x:Name="SectionGeneralPanel" Tag="genel baslangic bekleme idle" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Visible">
                                <StackPanel>
                                    <TextBlock Text="Genel" FontSize="20" FontWeight="Bold"/>
                                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Bilgisayar acildiginda otomatik baslat"/>
                                    <CheckBox x:Name="LightIdleModeCheckBox" Content="Hafif bekleme modunu kullan" Checked="OnLightIdleModeCheckBoxChanged" Unchecked="OnLightIdleModeCheckBoxChanged"/>
                                    <TextBlock x:Name="LightIdleModeDescriptionTextBlock" Foreground="{StaticResource MutedBrush}" Text="Kullanilmadiginda kaynak tuketimini azaltir." Margin="20,0,0,4"/>
                                    <Grid Margin="20,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Bekleme suresi" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="LightIdleDelayValueTextBlock" Grid.Column="1"/></Grid>
                                    <Slider x:Name="LightIdleDelaySlider" Margin="20,4,0,0" Minimum="5" Maximum="60" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OnLightIdleDelaySliderValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionAudioPanel" Tag="ses audio volume hover bildirim sessiz" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Ses" FontSize="20" FontWeight="Bold"/>
                                    <CheckBox x:Name="SoundsEnabledCheckBox" Content="Arayuz seslerini etkinlestir" Checked="OnSoundModeCheckBoxChanged" Unchecked="OnSoundModeCheckBoxChanged"/>
                                    <CheckBox x:Name="SilentModeCheckBox" Content="Sessiz mod (tum sesleri sustur)" Checked="OnSoundModeCheckBoxChanged" Unchecked="OnSoundModeCheckBoxChanged"/>
                                    <TextBlock x:Name="AudioHintTextBlock" Foreground="{StaticResource MutedBrush}" Margin="20,0,0,4" Text="Kisa mikro geri bildirim sesleri kullanilir."/>
                                    <Grid Margin="20,4,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Genel ses seviyesi" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="MasterVolumeValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="MasterVolumeSlider" Margin="20,4,0,0" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnMasterVolumeSliderValueChanged"/>
                                    <Grid Margin="20,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="UI ses seviyesi" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="UiVolumeValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="UiVolumeSlider" Margin="20,4,0,0" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnUiVolumeSliderValueChanged"/>
                                    <Grid Margin="20,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Hover ses seviyesi" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="HoverVolumeValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="HoverVolumeSlider" Margin="20,4,0,0" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnHoverVolumeSliderValueChanged"/>
                                    <Grid Margin="20,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Bildirim ses seviyesi" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="NotificationVolumeValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="NotificationVolumeSlider" Margin="20,4,0,0" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OnNotificationVolumeSliderValueChanged"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button x:Name="TestUiSoundButton" Width="170" Style="{StaticResource BaseButtonStyle}" Click="OnTestUiSoundClicked" Content="UI Sesini Test Et"/>
                                        <Button x:Name="TestNotificationSoundButton" Width="200" Margin="8,0,0,0" Style="{StaticResource BaseButtonStyle}" Click="OnTestNotificationSoundClicked" Content="Bildirim Sesini Test Et"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionControlsPanel" Tag="kontroller kisayol hedefleme" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Kontroller" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Menuyu Ac" Margin="0,8,0,4"/>
                                    <Button x:Name="OpenShortcutCaptureButton" Style="{StaticResource BaseButtonStyle}" Click="OnOpenShortcutCaptureClicked" HorizontalContentAlignment="Left"/>
                                    <TextBlock Text="Programi Ac/Kapat" Margin="0,8,0,4"/>
                                    <Button x:Name="ToggleShortcutCaptureButton" Style="{StaticResource BaseButtonStyle}" Click="OnToggleShortcutCaptureClicked" HorizontalContentAlignment="Left"/>
                                    <TextBlock Text="Hedefleme Tusu" Margin="0,8,0,4"/>
                                    <Button x:Name="TargetingShortcutCaptureButton" Style="{StaticResource BaseButtonStyle}" Click="OnTargetingShortcutCaptureClicked" HorizontalContentAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="SectionAppearancePanel" Tag="gorunum stil tema animasyon siyah beyaz hedefleme saat clock font" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Gorunum" FontSize="20" FontWeight="Bold"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Stil"/><ComboBox x:Name="StyleComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="Tema"/><ComboBox x:Name="ThemeComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/></StackPanel>
                                    </Grid>
                                    <TextBlock Text="Acilis Animasyonu" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="OpenAnimationComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/>
                                    <TextBlock Text="Hedefleme Stili" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="TargetingModeComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/>
                                    <TextBlock Text="Saat Fontu" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="CenterClockFontComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/>
                                    <CheckBox x:Name="HoverLabelsCheckBox" Content="Hover basliklarini goster" Margin="0,8,0,0"/>
                                    <CheckBox x:Name="CategoryLabelsCheckBox" Content="Kategori adlarini goster"/>
                                    <CheckBox x:Name="IconChromeCheckBox" Content="Ikon cercevesi ve parlama"/>
                                    <CheckBox x:Name="MonochromeBackdropCheckBox" Content="Arka planda siyah-beyaz filtre"/>
                                    <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Margin="0,8,0,0" Padding="8" Background="{StaticResource InputBrush}">
                                        <StackPanel>
                                            <TextBlock Text="Canli Onizleme" FontWeight="Bold"/>
                                            <Canvas x:Name="PreviewCanvas" Height="280"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionStripPanel" Tag="serit font opaklik renk" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Serit ve Font" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Serit Stili" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="CategoryStripStyleComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/>
                                    <TextBlock Text="Serit Fontu" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="CategoryStripFontComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Serit Opakligi" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="CategoryStripOpacityValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="CategoryStripOpacitySlider" Minimum="0.15" Maximum="1.0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Yazi Opakligi" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="CategoryStripFontOpacityValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="CategoryStripFontOpacitySlider" Minimum="0.15" Maximum="1.0"/>
                                    <Button Margin="0,8,0,0" Width="170" HorizontalAlignment="Left" Style="{StaticResource BaseButtonStyle}" Click="OnCategoryStripFontColorClicked">
                                        <StackPanel Orientation="Horizontal">
                                            <Border x:Name="CategoryStripFontColorSwatch" Width="16" Height="16" CornerRadius="8" Margin="0,0,8,0" BorderBrush="#FFFFFF" BorderThickness="1"/>
                                            <TextBlock Text="Yazi Rengi"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionRingsPanel" Tag="efekt blur halka cember gradient animasyon performans" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Efektler" FontSize="20" FontWeight="Bold"/>
                                    <CheckBox x:Name="GradientRingAnimationsCheckBox" Content="Gradient halka animasyonlarini etkinlestir" Margin="0,8,0,0"/>
                                    <CheckBox x:Name="MenuBackdropBlurCheckBox" Content="Arka planda radial blur efekti" Margin="0,6,0,0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Ic Gradient Halka" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="InnerGradientRingThicknessValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="InnerGradientRingThicknessSlider" Minimum="0.4" Maximum="2.5"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Dis Gradient Halka" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="OuterGradientRingThicknessValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="OuterGradientRingThicknessSlider" Minimum="0.4" Maximum="2.5"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Radial Blur Boyutu" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="MenuBackdropBlurSizeValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="MenuBackdropBlurSizeSlider" Minimum="0.6" Maximum="2.5"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Radial Blur Siddeti" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="MenuBackdropBlurStrengthValueText" Grid.Column="1"/></Grid>
                                    <Slider x:Name="MenuBackdropBlurStrengthSlider" Minimum="0.4" Maximum="2.5"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionWeatherPanel" Tag="hava durumu weather open meteo manuel otomatik gunduz gece bulut yagmur kar simsek dolu" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Hava Durumu" FontSize="20" FontWeight="Bold"/>
                                    <CheckBox x:Name="WeatherAnimationsEnabledCheckBox" Content="Hava durumu animasyonlarini etkinlestir" Margin="0,8,0,0" Checked="OnWeatherControlChanged" Unchecked="OnWeatherControlChanged"/>
                                    <CheckBox x:Name="WeatherUseLiveDataCheckBox" Content="Open-Meteo canli veriyi kullan (otomatik)" Margin="0,4,0,0" Checked="OnWeatherControlChanged" Unchecked="OnWeatherControlChanged"/>
                                    <TextBlock Foreground="{StaticResource MutedBrush}" Margin="20,0,0,4" Text="Canli veri kapaliysa manuel secilen hava durumu oynatilir."/>

                                    <TextBlock Text="Manuel Hava Durumu" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="WeatherManualPresetComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key" SelectionChanged="OnWeatherSelectionChanged"/>

                                    <TextBlock Text="Gunduz / Gece" Margin="0,8,0,4"/>
                                    <ComboBox x:Name="WeatherDayNightModeComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Key" SelectionChanged="OnWeatherSelectionChanged"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Animasyon Hiz Carpani" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="WeatherSpeedValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="WeatherSpeedSlider" Minimum="0.4" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnWeatherSliderValueChanged"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Animasyon Yogunluk Carpani" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="WeatherIntensityValueTextBlock" Grid.Column="1"/>
                                    </Grid>
                                    <Slider x:Name="WeatherIntensitySlider" Minimum="0.4" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="OnWeatherSliderValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionMenuPanel" Tag="menu oge sayfa alt menu" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Menu Icerigi" FontSize="20" FontWeight="Bold"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{StaticResource PanelBrushAlt}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                                <Border BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Background="{StaticResource InputBrush}"><WrapPanel x:Name="PageTabsPanel"/></Border>
                                                <Grid Grid.Row="1" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Background="{StaticResource InputBrush}">
                                                        <Grid AllowDrop="True" DragOver="OnItemsDragOver" Drop="OnItemsDrop">
                                                            <TreeView x:Name="MenuTreeView" Margin="8" MinHeight="220" MaxHeight="420" AllowDrop="True" PreviewMouseLeftButtonDown="OnTreePreviewMouseLeftButtonDown" MouseMove="OnTreeMouseMove" DragOver="OnTreeDragOver" Drop="OnTreeDrop" SelectedItemChanged="OnTreeSelectionChanged"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                        <Button x:Name="AddNewButton" Style="{StaticResource BaseButtonStyle}" Width="42" Height="42" Margin="0,0,0,6" Click="OnAddNewClicked" Content="+"/>
                                                        <Button Style="{StaticResource BaseButtonStyle}" Width="42" Height="42" Margin="0,0,0,6" Click="OnAddCategoryClicked" Content="&#x25A3;"/>
                                                        <Button x:Name="RemoveButton" Style="{StaticResource BaseButtonStyle}" Width="42" Height="42" Margin="0,0,0,6" Click="OnRemoveClicked" Content="X"/>
                                                        <Button x:Name="MoveUpButton" Style="{StaticResource BaseButtonStyle}" Width="42" Height="42" Margin="0,0,0,6" Click="OnMoveUpClicked" Content="&#x2191;"/>
                                                        <Button x:Name="MoveDownButton" Style="{StaticResource BaseButtonStyle}" Width="42" Height="42" Click="OnMoveDownClicked" Content="&#x2193;"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Background="{StaticResource PanelBrushAlt}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                <TextBlock Text="Oge Editoru" FontSize="18" FontWeight="Bold"/>
                                                <StackPanel Grid.Row="1" Margin="0,10,0,0"><TextBlock Text="Gorunen Ad"/><TextBox x:Name="LabelTextBox" TextChanged="OnEditorTextChanged" LostFocus="OnTextBoxLostFocus"/></StackPanel>
                                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                                    <TextBlock Text="Program veya Dosya Yolu"/>
                                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBox x:Name="TargetPathTextBox" Margin="0,0,8,0" TextChanged="OnEditorTextChanged" LostFocus="OnTextBoxLostFocus"/>
                                                        <Button Grid.Column="1" Width="100" Style="{StaticResource BaseButtonStyle}" Click="OnBrowseClicked" Content="Gozat"/>
                                                    </Grid>
                                                </StackPanel>
                                                <Button Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource BaseButtonStyle}" Click="OnEditChildrenClicked" Content="Alt Menuyu Duzenle"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="14,0,14,14" Padding="10" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Background="{StaticResource PanelBrush}">
                <DockPanel>
                    <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="Hazir"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Width="130" Margin="0,0,8,0" Style="{StaticResource BaseButtonStyle}" Click="OnResetToDefaultsClicked" Content="Varsayilanlar"/>
                        <Button Width="110" Margin="0,0,8,0" Style="{StaticResource BaseButtonStyle}" Click="OnCancelClicked" Content="Kapat"/>
                        <Button Width="150" Style="{StaticResource PrimaryButtonStyle}" Click="OnSaveSettingsClicked" Content="Ayarlari Kaydet"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
